# ============================================================
#  AI Financial Advisor — .gitignore
# ============================================================


# ------------------------------------------------------------
# 🔐 Environment & Secrets  (NEVER push these)
# ------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.cert


# ------------------------------------------------------------
# 📦 Node.js / Backend Dependencies
# ------------------------------------------------------------
node_modules/
backend/node_modules/
package-lock.json
backend/package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/


# ------------------------------------------------------------
# 📂 User Uploads  (runtime data — not source code)
# ------------------------------------------------------------
backend/uploads/
uploads/


# ------------------------------------------------------------
# 🐍 Python / AI Service
# ------------------------------------------------------------
# Virtual environments
python-ai/venv/
python-ai/.venv/
python-ai/env/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
python-ai/dist/
python-ai/build/
python-ai/*.egg-info/
python-ai/.eggs/

# Python testing & coverage
.pytest_cache/
.coverage
htmlcov/


# ------------------------------------------------------------
# 🖥️ OS Generated Files
# ------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~


# ------------------------------------------------------------
# 🛠️ IDEs & Editors
# ------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, PyCharm, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace


# ------------------------------------------------------------
# 📋 Logs & Debug Output
# ------------------------------------------------------------
logs/
*.log
*.log.*
pids/
*.pid
*.seed


# ------------------------------------------------------------
# 🏗️ Build Artifacts
# ------------------------------------------------------------
dist/
build/
out/
.cache/
.parcel-cache/


# ------------------------------------------------------------
# 🔧 Misc
# ------------------------------------------------------------
.temp/
.tmp/
*.bak
*.swp
*.swo
